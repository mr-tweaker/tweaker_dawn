<div class="page-width section-{{ section.id }}-padding">
  <div class="content-container" style="border: 1px solid rgba(255,255,255,.10); border-radius: 16px; padding: 18px;">
    <div class="rte">
      <h2 class="h2" style="margin-top:0; letter-spacing:.08em; text-transform:uppercase;">{{ section.settings.heading | escape }}</h2>
      <p style="color: rgba(170,170,180,1); margin-top: -6px;">{{ section.settings.subheading | escape }}</p>
    </div>

    <div style="display:grid; grid-template-columns: 1fr; gap: 14px;">
      <svg viewBox="0 0 320 360" role="img" aria-label="Back print placement" style="width:100%; max-width: 360px;">
        <defs>
          <linearGradient id="bg" x1="0" x2="0" y1="0" y2="1">
            <stop offset="0" stop-color="rgba(255,255,255,.06)"/>
            <stop offset="1" stop-color="rgba(255,255,255,.02)"/>
          </linearGradient>
        </defs>
        <rect x="10" y="10" width="300" height="340" rx="18" fill="url(#bg)" stroke="rgba(255,255,255,.10)"/>
        <!-- simplified tee outline -->
        <path d="M95 70c-16 8-30 20-44 35l-20 20 30 18 16-16v190c0 18 14 33 32 33h102c18 0 32-15 32-33V127l16 16 30-18-20-20c-14-15-28-27-44-35-8 10-20 16-34 16h-60c-14 0-26-6-34-16z"
              fill="rgba(0,0,0,.28)" stroke="rgba(255,255,255,.12)" stroke-width="2"/>
        <!-- print area -->
        <rect x="122" y="128" width="76" height="110" rx="10" fill="rgba(82,207,255,.12)" stroke="rgba(82,207,255,.65)" stroke-width="2"/>
        <text x="160" y="258" text-anchor="middle" font-size="12" fill="rgba(245,245,245,.86)" style="letter-spacing:.12em;">BACK PRINT</text>
      </svg>

      <div class="rte">
        {{ section.settings.body }}
      </div>
    </div>
  </div>
</div>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "TW back print",
  "tag": "section",
  "class": "section",
  "enabled_on": { "templates": ["product"] },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Back print placement" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Approximate placement • may vary slightly per piece" },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Printed on black cotton using DTF (fused). Best care: wash inside-out, cold wash, no iron directly on print.</p>"
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 20 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 20 }
  ],
  "presets": [{ "name": "Tweaker back print placement" }]
}
{% endschema %}

